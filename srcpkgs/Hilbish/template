post_extract() {
	mv -T inspect.lua-${_inspect_commit} ${pkgname}-${version}/libs/inspect
	mv -T Lunacolors-${_lunacolors_commit} ${pkgname}-${version}/libs/lunacolors
	mv -T Succulent-${_succulent_commit} ${pkgname}-${version}/libs/succulent
}

post_install() {
	vinstall LICENSE 644 usr/share/licenses/hilbish

	vmkdir usr/share/hilbish
	cp -r libs docs emmyLuaDocs nature .hilbishrc.lua ${DESTDIR}/usr/share/hilbish/
}
