post_extract() {
	mv -T argparse-${_argparse_revision} ${build_wrksrc}/vendor/argparse
	mv -T blip-buf-${_blip_buf_revision} ${build_wrksrc}/vendor/blip-buf
	mv -T lpeg-${_lpeg_revision} ${build_wrksrc}/vendor/lpeg
	mv -T moonscript-${_moonscript_revision} ${build_wrksrc}/vendor/moonscript
	mv -T squirrel-${_squirrel_revision} ${build_wrksrc}/vendor/squirrel
	mv -T wasm3-${_wasm_revision} ${build_wrksrc}/vendor/wasm3
	mv -T wren-${_wren_revision} ${build_wrksrc}/vendor/wren
	mv -T zip-${_zip_revision} ${build_wrksrc}/vendor/zip
}

post_install() {
	vmkdir usr/share/icons/hicolor/256x256/apps
	mv ${DESTDIR}/usr/share/icons/tic80.png ${DESTDIR}/usr/share/icons/hicolor/256x256/apps/

	vlicense LICENSE
}
